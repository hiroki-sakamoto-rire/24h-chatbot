# PostgreSQL 接続文字列
# ローカル開発例:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/chatbot?schema=public"

# 本番(Google Cloud SQL + Cloud Run)では Cloud SQL ソケット接続を利用:
# DATABASE_URL="postgresql://USER:PASSWORD@localhost/DB_NAME?host=/cloudsql/PROJECT:REGION:INSTANCE"

# アプリ環境
NODE_ENV="development"
