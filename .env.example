# ===== データベース (Cloud SQL for PostgreSQL) =====
# ローカル開発例:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/chatbot?schema=public"
# 本番(Google Cloud SQL + Cloud Run)では Cloud SQL ソケット接続を利用:
# DATABASE_URL="postgresql://USER:PASSWORD@localhost/DB_NAME?host=/cloudsql/PROJECT:REGION:INSTANCE"

# ===== tl;dv API =====
# https://tldv.io/app/settings/personal-settings/api-keys で発行 (Pro/Business/Enterprise プランが必要)
TLDV_API_KEY=""
# Webhook の簡易認証用シークレット。tl;dv の Webhook URL に ?secret=... を付けて設定する
TLDV_WEBHOOK_SECRET=""

# ===== Google Cloud Storage (録画の保存先) =====
GCP_PROJECT_ID=""
GCS_BUCKET=""
# ローカルでサービスアカウント鍵を使う場合のみ (Cloud Run 上では不要):
# GOOGLE_APPLICATION_CREDENTIALS="/path/to/service-account.json"

# ===== アプリ環境 =====
NODE_ENV="development"
